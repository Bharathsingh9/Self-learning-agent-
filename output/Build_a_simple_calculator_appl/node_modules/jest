// script.js
var display = document.getElementById('txtDisplay');
var val = '';

function append(x) {
  val += x;
  display.value = val;
}

function equal() {
  try {
    val = eval(val);
    display.value = val;
    val = '';
  } catch (e) {
    display.value = 'Error';
    var err = document.getElementById('error');
    err.style.display = 'block';
    setTimeout(() => {
      err.style.display = 'none';
    }, 2000);
  }
}

function clearcalc() {
  val = '';
  display.value = '';
}

function backspace() {
  val = val.substring(0, val.length - 1);
  display.value = val;
}

function evalcalc() {
  try {
    val = eval(val);
    display.value = val;
    val = '';
  } catch (e) {
    display.value = 'Invalid Input';
  }
}

setInterval(() => {
  display.value = val;
}, 100);
