// calculator.test.js
import Calculator from './script';
import React from 'react';
import { render, fireEvent, waitFor } from '@testing-library/react';
import { configure, mount } from 'enzyme';
import Adapter from '@wojtekmaj/enzyme-adapter-react-17';

configure({ adapter: new Adapter() });

describe('Calculator', () => {
  it('calculates addition correctly', async () => {
    const { getByText } = render(<Calculator />);
    const button1 = getByText('1');
    const button2 = getByText('+');
    const button3 = getByText('1');
    const button4 = getByText('=');

    fireEvent.click(button1);
    fireEvent.click(button2);
    fireEvent.click(button3);
    fireEvent.click(button4);

    await waitFor(() => expect(getByText('2')).toBeInTheDocument());
  });

  it('calculates subtraction correctly', async () => {
    const { getByText } = render(<Calculator />);
    const button1 = getByText('10');
    const button2 = getByText('-');
    const button3 = getByText('2');
    const button4 = getByText('=');

    fireEvent.click(button1);
    fireEvent.click(button2);
    fireEvent.click(button3);
    fireEvent.click(button4);

    await waitFor(() => expect(getByText('8')).toBeInTheDocument());
  });

  it('throws an error when trying to divide by zero', async () => {
    const { getByText } = render(<Calculator />);
    const button1 = getByText('1');
    const button2 = getByText('/');
    const button3 = getByText('0');
    const button4 = getByText('=');

    fireEvent.click(button1);
    fireEvent.click(button2);
    fireEvent.click(button3);
    fireEvent.click(button4);

    await waitFor(() =>
      expect(getByText(/invalid input/i)).toBeInTheDocument()
    );
  });
});



